# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_URL=postgresql://habit_tracker:habit_tracker@db:5432/habit_tracker

# Admin — first user with this email gets admin role
ADMIN_EMAILS=admin@example.com

# SSO — Microsoft Entra ID (leave unset for dev login fallback)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# SSO — Google Workspace (leave unset for dev login fallback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
